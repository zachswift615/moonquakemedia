<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}{% if title %} | {% endif %}{{ site.name }}</title>
    {% if description %}
    <meta name="description" content="{{ description }}">
    {% endif %}

    <!-- Apple Smart App Banner -->
    <meta name="apple-itunes-app" content="app-id=6755753624">

    <!-- Open Graph -->
    <meta property="og:title" content="{{ ogTitle or title }}{% if title %} | {% endif %}{{ site.name }}">
    <meta property="og:description" content="{{ ogDescription or description or site.tagline }}">
    <meta property="og:type" content="{{ ogType or 'website' }}">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:image" content="{{ site.url }}{{ ogImage or '/images/og-default.png' }}">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ ogTitle or title }}{% if title %} | {% endif %}{{ site.name }}">
    <meta name="twitter:description" content="{{ ogDescription or description or site.tagline }}">
    <meta name="twitter:image" content="{{ site.url }}{{ ogImage or '/images/og-default.png' }}">

    <!-- Google Search Console -->
    <meta name="google-site-verification" content="pWAcs0monFAO6yO10RzsFqi0N_AsM7VPJNnKKpAUy0s">

    <!-- Canonical URL -->
    <link rel="canonical" href="{{ site.url }}{{ page.url }}">

    <!-- Article metadata -->
    {% if date and ogType == "article" %}
    <meta property="article:published_time" content="{{ date | isoDate }}">
    {% endif %}

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/images/favicon-32.png">
    <link rel="apple-touch-icon" sizes="180x180" href="/images/apple-touch-icon.png">

    {% block head %}{% endblock %}

    <link rel="stylesheet" href="/css/main.css">
    <link rel="alternate" type="application/rss+xml" title="{{ site.name }} Blog" href="/blog/feed.xml">
</head>
<body class="{% block bodyClass %}{% endblock %}">
    <a href="#main-content" class="skip-link">Skip to main content</a>
    {% block content %}{{ content | safe }}{% endblock %}

    {% block footer %}
    {% include "components/footer.njk" %}
    {% endblock %}

    {% block scripts %}{% endblock %}
</body>
</html>

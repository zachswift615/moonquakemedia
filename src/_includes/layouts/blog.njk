---
layout: layouts/base.njk
ogType: article
rss: true
---
<div class="min-h-screen bg-white">
  <!-- Navigation -->
  <nav class="border-b border-gray-100 bg-white" aria-label="Main navigation">
    <div class="max-w-2xl mx-auto px-6 py-5 flex justify-between items-center">
      <a href="/" class="text-base font-semibold text-gray-950 no-underline tracking-tight hover:text-gray-600 hover:no-underline transition-colors">{{ site.name }}</a>
      <div class="flex gap-6 items-center">
        <a href="/apps/listen2/" class="text-sm text-gray-500 no-underline hover:text-gray-950 hover:no-underline transition-colors">Listen2</a>
        <a href="/blog/" class="text-sm text-gray-500 no-underline hover:text-gray-950 hover:no-underline transition-colors">Blog</a>
        <a href="mailto:{{ site.email }}" class="text-sm text-gray-500 no-underline hover:text-gray-950 hover:no-underline transition-colors">Support</a>
      </div>
    </div>
  </nav>

  <!-- Article -->
  <main id="main-content">
    <article class="max-w-2xl mx-auto px-6 pt-16 pb-20">
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <time datetime="{{ date | isoDate }}" class="text-xs text-gray-500 font-medium tracking-wide uppercase">{{ date | readableDate }}</time>
          <span class="text-gray-300" aria-hidden="true">&middot;</span>
          <span class="text-xs text-gray-500">{{ content | readingTime }}</span>
        </div>
        <h1 class="text-2xl md:text-3xl font-bold text-gray-950 leading-tight tracking-tight">{{ title }}</h1>
      </header>

      <div class="prose prose-gray max-w-none prose-headings:text-gray-950 prose-headings:tracking-tight prose-headings:font-semibold prose-p:text-gray-500 prose-p:leading-relaxed prose-li:text-gray-500 prose-a:text-gray-950 prose-a:underline prose-a:underline-offset-2 prose-a:decoration-gray-300 hover:prose-a:decoration-gray-950 prose-img:rounded-xl prose-strong:text-gray-700 prose-blockquote:text-gray-400 prose-blockquote:border-gray-200">
        {{ content | safe }}
      </div>

      <footer class="mt-20 pt-8 border-t border-gray-100">
        <a href="/blog/" class="text-sm text-gray-500 font-medium no-underline hover:text-gray-950 hover:no-underline transition-colors">&larr; All posts</a>
      </footer>
    </article>
  </main>
</div>
